# Local-only files — never commit credentials, client data, or machine config.

# Each TAM's own client list — created locally, never committed.
# Matches at any depth; the explicit path documents where it now lives.
clients.yml
/.cursor/skills/airship-kpi-monitor/clients.yml

# Local HTML dashboard data — written by the skill each run (no secrets, but
# contains client routing/state). The dashboard app itself (index.html,
# styles.css, app.js, dashboard-data.sample.js) IS committed.
/.cursor/skills/airship-kpi-monitor/dashboard/dashboard-data.js

# Optional bulk-generator secrets (OAuth creds + local airship-mcp path).
clients.secrets.yml
*.secrets.yml

# Cursor MCP config (lives in ~/.cursor/mcp.json; only copied here for debugging).
mcp.json
mcp.json.bak

# Python / tooling cruft
__pycache__/
*.pyc
.venv/
.DS_Store
